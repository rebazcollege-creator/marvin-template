# ─────────────────────────────────────────────────────────────
# Xanî — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API
ANTHROPIC_API_KEY=

# ── Gmail — 5 accounts, one OAuth set per account ──
GMAIL_CLIENT_ID_1=          # Personal
GMAIL_CLIENT_SECRET_1=
GMAIL_REFRESH_TOKEN_1=

GMAIL_CLIENT_ID_2=          # Moonshot
GMAIL_CLIENT_SECRET_2=
GMAIL_REFRESH_TOKEN_2=

GMAIL_CLIENT_ID_3=          # LeadStories  (read/alert only — no automated sending)
GMAIL_CLIENT_SECRET_3=
GMAIL_REFRESH_TOKEN_3=

GMAIL_CLIENT_ID_4=          # Zoho personal
GMAIL_CLIENT_SECRET_4=
GMAIL_REFRESH_TOKEN_4=

GMAIL_CLIENT_ID_5=          # Amargi socials
GMAIL_CLIENT_SECRET_5=
GMAIL_REFRESH_TOKEN_5=

# ── Google Calendar ──
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ── Zapier MCP (Trello) ──
ZAPIER_MCP_SERVER_URL=https://mcp.zapier.com/api/v1/connect
ZAPIER_API_KEY=

# ── Notion ──
NOTION_INTEGRATION_TOKEN=

# ── Slack (Amargi — direct MCP already configured externally) ──
# ── Slack (LeadStories — separate OAuth; read/monitor only) ──
SLACK_LEADSTORIES_BOT_TOKEN=
SLACK_LEADSTORIES_APP_TOKEN=

# ── Buffer (Direct MCP) ──
BUFFER_ACCESS_TOKEN=
