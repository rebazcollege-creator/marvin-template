# ─────────────────────────────────────────────────────────────
# Xanî — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API — consumed by the Node sidecar only (never the renderer).
# In the packaged app this is sourced from the OS keychain and passed to the
# sidecar via env at spawn.
ANTHROPIC_API_KEY=

# MARVIN sidecar URL the renderer talks to (dev default shown). Not a secret.
NEXT_PUBLIC_MARVIN_SIDECAR_URL=http://localhost:8787

# ── Gmail — 5 accounts, one OAuth set per account ──
GMAIL_CLIENT_ID_1=          # Personal
GMAIL_CLIENT_SECRET_1=
GMAIL_REFRESH_TOKEN_1=

GMAIL_CLIENT_ID_2=          # Moonshot
GMAIL_CLIENT_SECRET_2=
GMAIL_REFRESH_TOKEN_2=

GMAIL_CLIENT_ID_3=          # LeadStories  (read/alert only — no automated sending)
GMAIL_CLIENT_SECRET_3=
GMAIL_REFRESH_TOKEN_3=

GMAIL_CLIENT_ID_4=          # Zoho personal
GMAIL_CLIENT_SECRET_4=
GMAIL_REFRESH_TOKEN_4=

GMAIL_CLIENT_ID_5=          # Amargi socials
GMAIL_CLIENT_SECRET_5=
GMAIL_REFRESH_TOKEN_5=

# ── Google Calendar ──
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ── Google Drive ──
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── Trello (REST: API key + token + board) ──
# Used by the sidecar to read cards and (on approval) create them.
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=683dafe308be04e369b8434c

# ── Zapier MCP (Trello — alternative routing) ──
ZAPIER_MCP_SERVER_URL=https://mcp.zapier.com/api/v1/connect
ZAPIER_API_KEY=

# ── Notion ──
NOTION_INTEGRATION_TOKEN=

# ── Slack ──
# Amargi bot token — read-only monitor of #general + #tt-arabic (sidecar uses this).
SLACK_AMARGI_BOT_TOKEN=
# LeadStories — separate OAuth; read/monitor only, never written to.
SLACK_LEADSTORIES_BOT_TOKEN=
SLACK_LEADSTORIES_APP_TOKEN=

# ── Buffer (Direct MCP) ──
BUFFER_ACCESS_TOKEN=
